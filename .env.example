# 토스증권 OpenAPI 자격증명 — 실제 값은 .env에 넣고 .env는 절대 커밋하지 않는다.
# Phase 0-1에서 developers.tossinvest.com 승인 후 발급받은 값.
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Base URL (openapi.json 정본 기준, 보통 수정 불필요)
TOSS_BASE_URL=https://openapi.tossinvest.com

# Phase 0-2에서 `GET /api/v1/accounts` 응답으로 확인한 계좌식별자.
# 처음엔 비워두고, scripts/phase0/01_accounts.py 실행 결과를 여기에 채운다.
TOSS_ACCOUNT=
